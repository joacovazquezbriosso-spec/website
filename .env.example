# Database
# Local dev: SQLite
DATABASE_URL="file:./dev.db"

# Production: Vercel Postgres (set automatically by Vercel when you connect a Postgres database)
# DATABASE_URL="postgresql://..."
# DIRECT_URL="postgresql://..."

# Admin auth
# Generate with: openssl rand -hex 32
ADMIN_PASSWORD="your-secure-password"
ADMIN_SESSION_TOKEN="your-random-secret-token"
